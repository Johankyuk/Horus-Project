    prefer-no-csd
    screenshot-path null

    environment {
        ELECTRON_OZONE_PLATFORM_HINT "auto"
        QT_QPA_PLATFORM "wayland"
        // qt6ct: las apps Qt (PCManFM-Qt...) toman la paleta Horus que genera
        // horus-theme. Era "gtk3" en la era Thunar (Qt seguia al tema GTK).
        QT_QPA_PLATFORMTHEME "qt6ct"
        QT_WAYLAND_DISABLE_WINDOWDECORATION "1"
        XDG_CURRENT_DESKTOP "niri"
        XDG_SESSION_TYPE "wayland"
    }


    debug {
        render-drm-device "/dev/dri/by-path/pci-0000:65:00.0-render"
        // Allows notification actions and window activation from Noctalia.
        honor-xdg-activation-with-invalid-serial
    }

    hotkey-overlay {
       skip-at-startup
    }

    // Blur de fondo (Niri >=26.04). Parámetros fuertes ("bastante"): sube 'offset'
    // primero (gratis en GPU) y 'passes' solo si aparecen artefactos. Por defecto
    // usa xray (difumina el wallpaper una vez y lo reusa: lo más eficiente).
    blur {
        passes 4
        offset 5
        noise 0.02
        saturation 1.5
    }
