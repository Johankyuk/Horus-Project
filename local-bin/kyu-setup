#!/bin/bash
# Autor: Kyu
# Lanzador de setup_master.sh. NO esta atado a una ruta fija: se autolocaliza.
# Orden de resolucion del repo:
#   1) variable de entorno KYU_OS_DIR, si esta definida
#   2) ~/.config/kyu-os/repo (archivo con la ruta; lo escribe bootstrap/setup)
#   3) busqueda en rutas comunes donde suele vivir el clon
# Vive en ~/.local/bin (en PATH) y el setup lo despliega ahi, asi que viaja
# con el repo a cualquier maquina sin editar nada.
set -uo pipefail

_find_repo() {
    if [ -n "${KYU_OS_DIR:-}" ] && [ -f "$KYU_OS_DIR/setup_master.sh" ]; then
        echo "$KYU_OS_DIR"; return
    fi
    local conf="$HOME/.config/kyu-os/repo"
    if [ -f "$conf" ] && [ -f "$(cat "$conf")/setup_master.sh" ]; then
        cat "$conf"; return
    fi
    local d
    for d in "$HOME/kyu-os" "$HOME/Proyectos/kyu-os" "$HOME/Documentos/kyu-os" \
             "$HOME/Documentos/Configs" "$HOME/.local/share/kyu-os"; do
        [ -f "$d/setup_master.sh" ] && { echo "$d"; return; }
    done
}

REPO="$(_find_repo)"
if [ -z "$REPO" ]; then
    echo "kyu-setup: no encuentro el repo de Kyu OS." >&2
    echo "  Defini la ruta con:  echo /ruta/al/repo > ~/.config/kyu-os/repo" >&2
    echo "  o exporta:           KYU_OS_DIR=/ruta/al/repo" >&2
    exit 1
fi
exec bash "$REPO/setup_master.sh" "$@"
