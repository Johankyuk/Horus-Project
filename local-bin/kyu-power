#!/usr/bin/env bash
# ============================================================
# Autor: Kyu
# kyu-power — perfiles de energía de Kyu OS.
#
#   kyu-power ahorro       dGPU APAGADA (supergfxctl Integrated) + perfil quiet.
#                          Máxima batería y temperatura mínima. El escritorio pasa
#                          a la iGPU 780M; la RTX deja de consumir.
#                          OJO: cambiar el modo de GPU CIERRA SESIÓN (pide confirmar).
#   kyu-power equilibrado  dGPU on-demand (Hybrid) + balanced + power-limit default.
#   kyu-power rendimiento  dGPU activa (Hybrid) + performance + power-limit 60W +
#                          curva de ventiladores agresiva.
#   kyu-power --actual     muestra el estado actual.
#
# El modo de GPU (ahorro = Integrated vs el resto = Hybrid) lo maneja supergfxctl
# y requiere re-login. El perfil de fans/EC y el power-limit son instantáneos.
# Solo nvidia-smi -pl necesita sudo; supergfxctl/powerprofilesctl/asusctl van por
# D-Bus (polkit), sin sudo.
# ============================================================
set -uo pipefail

P='\033[0;35m'; G='\033[0;32m'; Y='\033[1;33m'; R='\033[0;31m'; N='\033[0m'
log()  { echo -e "${P}[power]${N} $1"; }
ok()   { echo -e "${G}[+]${N} $1"; }
warn() { echo -e "${Y}[i]${N} $1"; }
err()  { echo -e "${R}[x]${N} $1"; }

PL_RENDIMIENTO=60   # watts de la dGPU en rendimiento (seguro: el VBIOS clampa al techo real)
CURVA="30c:20%,45c:35%,55c:55%,65c:75%,72c:90%,80c:100%,87c:100%,95c:100%"

# ── supergfxd debe estar activo para tocar el modo de GPU ────
_asegura_supergfxd() {
    if systemctl is-active supergfxd &>/dev/null; then return 0; fi
    warn "supergfxd no está activo; habilitándolo (una vez, pide sudo)..."
    sudo systemctl enable --now supergfxd && ok "supergfxd habilitado." || {
        err "No se pudo habilitar supergfxd."; return 1; }
}

_perfil() {  # $1 = power-saver | balanced | performance
    if powerprofilesctl set "$1" 2>/dev/null; then ok "Perfil EC -> $1"
    else warn "No se pudo fijar el perfil $1 (¿power-profiles-daemon?)."; fi
}

_powerlimit() {  # $1 = watts | 'default'
    command -v nvidia-smi &>/dev/null || { warn "nvidia-smi no disponible; sin power-limit."; return; }
    local w="$1"
    if [ "$w" = "default" ]; then
        w=$(nvidia-smi --query-gpu=power.default_limit --format=csv,noheader,nounits 2>/dev/null | cut -d. -f1)
    fi
    [ -n "$w" ] || { warn "No pude leer el power-limit; se omite."; return; }
    if sudo nvidia-smi -pl "$w" &>/dev/null; then ok "Power-limit dGPU -> ${w}W"
    else warn "No se pudo fijar el power-limit (¿dGPU dormida en Integrated?)."; fi
}

_curva_perf() {
    command -v asusctl &>/dev/null || { warn "asusctl no disponible; sin curva."; return; }
    asusctl fan-curve --mod-profile performance --fan cpu --data "$CURVA" &>/dev/null
    asusctl fan-curve --mod-profile performance --fan gpu --data "$CURVA" &>/dev/null
    asusctl fan-curve --mod-profile performance --enable-fan-curves true &>/dev/null
    ok "Curva agresiva aplicada al perfil performance."
}

_curva_default() {  # $1 = perfil
    command -v asusctl &>/dev/null || return
    asusctl fan-curve --mod-profile "$1" --default &>/dev/null && ok "Curva de '$1' a default."
}

_modo_gpu() {  # $1 = Integrated | Hybrid
    _asegura_supergfxd || return
    local actual; actual=$(supergfxctl -g 2>/dev/null)
    if [ "$actual" = "$1" ]; then ok "Modo GPU ya en $1."; return; fi
    warn "Cambiar el modo de GPU ($actual -> $1) CIERRA SESIÓN."
    if [ -t 0 ]; then
        read -rp "  ¿Continuar? [s/N] " r
        [[ "$r" =~ ^[sS]$ ]] || { log "Cancelado; modo de GPU sin cambios."; return 1; }
    fi
    supergfxctl -m "$1" && log "Modo -> $1. Se cerrará la sesión para aplicar." \
        || err "No se pudo cambiar el modo de GPU."
}

case "${1:-}" in
    ahorro|ahor)
        _modo_gpu Integrated || exit 0
        _perfil power-saver
        ok "Ahorro: dGPU apagada + quiet."
        ;;
    equilibrado|equi|eq)
        _modo_gpu Hybrid || true
        _perfil balanced
        _powerlimit default
        _curva_default balanced
        ok "Equilibrado: dGPU on-demand + balanced + power default."
        ;;
    rendimiento|rend|re)
        _modo_gpu Hybrid || true
        _perfil performance
        _powerlimit "$PL_RENDIMIENTO"
        _curva_perf
        ok "Rendimiento: dGPU a ${PL_RENDIMIENTO}W + performance + curva agresiva."
        ;;
    --actual|actual)
        echo "Modo GPU:   $(supergfxctl -g 2>/dev/null || echo '? (supergfxd inactivo)')"
        echo "Perfil EC:  $(powerprofilesctl get 2>/dev/null || echo '?')"
        if command -v nvidia-smi &>/dev/null; then
            echo "Power dGPU: $(nvidia-smi --query-gpu=power.limit --format=csv,noheader 2>/dev/null || echo 'dormida')"
        fi
        ;;
    *)
        echo "uso: kyu-power [ahorro|equilibrado|rendimiento|--actual]"
        ;;
esac
