#!/usr/bin/env bash
# kyu-verifica — compara repo vs ~/.config. Autor: Kyu
REPO="$HOME/Documentos/Configs/config"
P='\033[0;35m'; G='\033[0;32m'; Y='\033[1;33m'; N='\033[0m'
DIFFS=0
for item in niri foot noctalia/settings.json; do
    src="$REPO/$item"; dst="$HOME/.config/$item"
    [ -e "$dst" ] || { echo -e "${Y}[falta]${N} $dst no existe"; continue; }
    if diff -rq "$src" "$dst" &>/dev/null; then
        echo -e "${G}[=]${N} $item idéntico"
    else
        echo -e "${P}[≠]${N} $item difiere:"
        diff -rq "$src" "$dst" | sed 's/^/      /'
        DIFFS=1
    fi
done
[ $DIFFS -eq 0 ] && echo -e "\n${G}Todo sincronizado. Correr el flujo completo no pisa nada.${N}" \
                 || echo -e "\n${Y}Hay cambios locales sin capturar. Usa './setup_master.sh --capturar' antes de desplegar.${N}"
