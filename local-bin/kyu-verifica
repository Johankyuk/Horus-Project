#!/usr/bin/env bash
# kyu-verifica — compara los dotfiles del repo vs tu ~/.config activa. Autor: Kyu
# Se autolocaliza: usa KYU_OS_DIR o lee ~/.config/kyu-os/repo.
KYU_OS_DIR="${KYU_OS_DIR:-$(cat "$HOME/.config/kyu-os/repo" 2>/dev/null)}"
REPO="$KYU_OS_DIR/config"
[ -d "$REPO" ] || { echo "kyu-verifica: no encuentro el repo (define ~/.config/kyu-os/repo o KYU_OS_DIR)" >&2; exit 1; }
P="\033[0;35m"; G="\033[0;32m"; Y="\033[1;33m"; N="\033[0m"
DIFFS=0
for item in niri foot noctalia/settings.json; do
    src="$REPO/$item"; dst="$HOME/.config/$item"
    [ -e "$dst" ] || { echo -e "${Y}[falta]${N} $dst no existe"; continue; }
    if diff -rq "$src" "$dst" &>/dev/null; then
        echo -e "${G}[=]${N} $item identico"
    else
        echo -e "${P}[!=]${N} $item difiere:"
        diff -rq "$src" "$dst" | sed "s/^/      /"
        DIFFS=1
    fi
done
[ $DIFFS -eq 0 ] && echo -e "\n${G}Todo sincronizado. Correr el flujo completo no pisa nada.${N}" \
                 || echo -e "\n${Y}Hay cambios locales sin capturar. Usa kyu-sync antes de desplegar.${N}"
