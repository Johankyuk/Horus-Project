#!/usr/bin/env python3
# horus-theme — Aplica un tema de Horus Project a todo el sistema.
#   Fuente unica de color: horus_themes.py. De ahi sale la paleta de
#   cualquier tema y se propaga a Noctalia, foot, Niri y el wallpaper.
#   Resuelve el doble rol de algunos hex (p.ej. #c44fe6 = secondary en
#   Niri pero magenta-ANSI en la terminal) con reglas por-archivo.
#
#   Uso:
#     horus-theme <Tema>      aplica el tema (Morada, Azul rey, Rojo, Gris...)
#     horus-theme --lista     muestra los temas disponibles
#     horus-theme --actual    muestra el tema activo
#
#   Idempotente: solo escribe lo que cambia, respalda antes de tocar, y
#   resume al final que se movio. No edita a mano: regenera desde el motor.
import sys, os, re, json, shutil, subprocess, datetime, unicodedata, time, difflib

# ── Localizar repo y motor (mismo criterio que horus-start) ────
def _localizar_repo():
    for c in (os.environ.get("HORUS_DIR"),
              os.path.expanduser("~/.config/horus/repo"),
              os.path.expanduser("~/Horus-Project")):
        if c and os.path.isfile(os.path.join(c, "horus_themes.py")):
            return os.path.abspath(c)
    # fallback: junto a este script
    here = os.path.dirname(os.path.abspath(__file__))
    for c in (here, os.path.dirname(here)):
        if os.path.isfile(os.path.join(c, "horus_themes.py")):
            return c
    sys.exit("[err] No encuentro horus_themes.py (define HORUS_DIR).")

REPO = _localizar_repo()
sys.path.insert(0, REPO)
import horus_themes as kt

# ── Resolución tolerante de nombres de tema ──────────────────
# Acepta el nombre sin importar mayúsculas ni acentos: "azul rey",
# "AZUL REY", "Azul Eléctrico" -> el canónico de horus_themes. Cualquier
# script que reciba un tema debe pasar por aquí (no comparar crudo).
def _norm(s):
    s = unicodedata.normalize("NFD", s)
    s = "".join(c for c in s if unicodedata.category(c) != "Mn")
    return " ".join(s.split()).lower()

def _resolver_tema(entrada):
    """Devuelve el nombre canónico del tema, o None si no existe.
    Tolera mayúsculas, acentos, typos ('azul electirco') y orden/partes."""
    objetivo = _norm(entrada)
    canon = {_norm(t): t for t in kt.lista_temas()}
    # 1) exacto (ya normalizado: sin acentos ni mayúsculas)
    if objetivo in canon:
        return canon[objetivo]
    # 2) alias de nombres viejos
    alias = {"morada": "Morado"}
    if objetivo in alias:
        return alias[objetivo]
    # 3) fuzzy: tolera erratas ('azul electirco' -> 'Azul electrico')
    cerca = difflib.get_close_matches(objetivo, list(canon), n=1, cutoff=0.72)
    if cerca:
        return canon[cerca[0]]
    # 4) por palabras: si el input contiene todas las palabras de algún tema
    inp = set(objetivo.split())
    for nk, nt in canon.items():
        tks = set(nk.split())
        if tks and tks.issubset(inp):
            return nt
    return None

def _hex_rgb(h):
    h = h.lstrip("#")
    return int(h[0:2], 16), int(h[2:4], 16), int(h[4:6], 16)

def _swatch(hexc):
    """Bloque de color truecolor para el selector (muestra el primary real)."""
    r, g, b = _hex_rgb(hexc)
    return f"\033[48;2;{r};{g};{b}m    \033[0m"

HOME     = os.path.expanduser("~")
CFG      = os.path.join(HOME, ".config")
REPO_CFG = os.path.join(REPO, "config")   # fuente Morada: SIEMPRE se parte de aqui
STATE   = os.path.join(CFG, "horus", "tema")
BK_ROOT = os.path.join(HOME, ".cache", "horus", "tema-backups")
SVG_BASE = os.path.join(REPO, "Wallpapers", "base.svg")
WALL_DIR = os.path.join(REPO, "Wallpapers")

# Conjuntos de color con doble rol — se anclan por-archivo.
ANSI_FIJOS = {v.lstrip('#').lower() for v in kt.ANSI_FIJOS.values()}  # red/green/.../bright
NIRI_ROTAN = ["7a2be8", "482a92", "b340e0"]   # decorativos; urgent (f5567a) queda fijo

C = {"ok": "\033[92m", "warn": "\033[93m", "p": "\033[95m", "n": "\033[0m"}
def did(m):  print(f"{C['ok']}[+]{C['n']} {m}")
def skip(m): print(f"{C['p']}[=]{C['n']} {m}")
def warn(m): print(f"{C['warn']}[i]{C['n']} {m}")

_CAMBIOS = [False]
def _backup(path, ts):
    if os.path.exists(path):
        rel = os.path.relpath(path, HOME)
        dst = os.path.join(BK_ROOT, ts, rel)
        os.makedirs(os.path.dirname(dst), exist_ok=True)
        shutil.copy2(path, dst)

def _escribe_si_cambia(path, contenido, etiqueta, ts):
    if os.path.isfile(path) and open(path, encoding="utf-8").read() == contenido:
        skip(f"{etiqueta}: ya estaba al dia."); return
    _backup(path, ts)
    os.makedirs(os.path.dirname(path), exist_ok=True)
    with open(path, "w", encoding="utf-8") as f:
        f.write(contenido)
    did(etiqueta); _CAMBIOS[0] = True

def _sub_hex(texto, rotar_pred, tema):
    """Reemplaza cada hex de 6 chars segun rotar_pred(hex_lower)->bool."""
    def r(m):
        h = m.group(0).lower()
        return kt.rotar_hex("#" + h, tema).lstrip("#") if rotar_pred(h) else m.group(0)
    return re.sub(r'(?<![0-9a-fA-F])[0-9a-fA-F]{6}(?![0-9a-fA-F])', r, texto)

# ── 1) Colorscheme de Noctalia: dark + light generados desde roles ──
def _bloque(q, on, ons):
    return {
        "mPrimary": q["mPrimary"], "mOnPrimary": on,
        "mSecondary": q["mSecondary"], "mOnSecondary": on,
        "mTertiary": q["mTertiary"], "mOnTertiary": on,
        "mError": q["mError"], "mOnError": on,
        "mSurface": q["mSurface"], "mOnSurface": ons,
        "mSurfaceVariant": q["mSurfaceVariant"], "mOnSurfaceVariant": q["mOnSurfaceVariant"],
        "mOutline": q["mOutline"], "mShadow": q["mShadow"],
        "mHover": q["mHover"], "mOnHover": ons,
        "terminal": {
            "foreground": q["termFg"], "background": q["termBg"],
            "selectionFg": q["termSelFg"], "selectionBg": q["termSelBg"],
            "cursorText": q["termBg"], "cursor": q["termCursor"],
            "normal": {"black": q["black"], "red": q["red"], "green": q["green"],
                       "yellow": q["yellow"], "blue": q["blue"], "magenta": q["magenta"],
                       "cyan": q["cyan"], "white": q["white"]},
            "bright": {"black": q["blackBright"], "red": q["redBright"], "green": q["greenBright"],
                       "yellow": q["yellowBright"], "blue": q["blueBright"], "magenta": q["magentaBright"],
                       "cyan": q["cyanBright"], "white": q["whiteBright"]},
        },
    }

def gen_colorscheme(tema, ts):
    p  = kt.construir(tema)          # modo oscuro
    pl = kt.construir_light(tema)    # modo claro (paleta propia del tema)
    dark  = _bloque(p,  p["mOnPrimary"],  p["mOnSurface"])
    light = _bloque(pl, pl["mOnPrimary"], pl["mOnSurface"])
    dst = os.path.join(CFG, "noctalia", "colorschemes", "Horus Project", "Horus Project.json")
    base = {"dark": dark, "light": light}
    _escribe_si_cambia(dst, json.dumps(base, indent=2, ensure_ascii=False) + "\n",
                       f"Colorscheme Noctalia (dark+light) -> {tema}", ts)

# ── 2) foot: parchea colores (ANSI semanticos quedan fijos) ──
def gen_foot(tema, ts):
    src = os.path.join(REPO_CFG, "foot", "foot.ini")      # fuente Morada
    dst = os.path.join(CFG, "foot", "foot.ini")
    if not os.path.isfile(src):
        warn("foot.ini (repo) no encontrado; se omite."); return
    txt = open(src, encoding="utf-8").read()
    out = _sub_hex(txt, lambda h: h not in ANSI_FIJOS, tema)
    _escribe_si_cambia(dst, out, f"foot.ini -> {tema}", ts)

def recolorear_terminales():
    # foot NO recarga colores en caliente; pero SI obedece secuencias OSC en vivo.
    # Se le manda la paleta recien escrita en foot.ini a cada pty del usuario:
    # las terminales abiertas (incluida esta) se pintan del tema al instante.
    ini = os.path.join(CFG, "foot", "foot.ini")
    if not os.path.isfile(ini): return
    sec, colores = False, {}
    for ln in open(ini, encoding="utf-8"):
        ln = ln.strip()
        if ln.startswith("["):
            sec = (ln == "[colors-dark]"); continue
        if sec and "=" in ln:
            k, v = ln.split("=", 1)
            colores[k.strip()] = v.strip()
    seq = ""
    if "foreground" in colores: seq += f"\033]10;#{colores['foreground']}\a"
    if "background" in colores: seq += f"\033]11;#{colores['background']}\a"
    for i in range(8):
        if f"regular{i}" in colores: seq += f"\033]4;{i};#{colores[f'regular{i}']}\a"
        if f"bright{i}"  in colores: seq += f"\033]4;{i+8};#{colores[f'bright{i}']}\a"
    if not seq: return
    import glob as _g
    for pts in _g.glob("/dev/pts/[0-9]*"):
        if os.access(pts, os.W_OK):
            try:
                with open(pts, "w") as h: h.write(seq)
            except Exception: pass
    did("Terminales vivas recoloreadas (OSC).")

# ── 3) Niri: parchea solo los decorativos (urgent queda rojo) ─
def patch_niri(tema, ts):
    src = os.path.join(REPO_CFG, "niri", "cfg", "layout.kdl")  # fuente Morada
    dst = os.path.join(CFG, "niri", "cfg", "layout.kdl")
    if not os.path.isfile(src):
        warn("layout.kdl (repo) no encontrado; se omite."); return
    txt = open(src, encoding="utf-8").read()
    out = _sub_hex(txt, lambda h: h in NIRI_ROTAN, tema)
    _escribe_si_cambia(dst, out, f"Niri layout.kdl -> {tema}", ts)

# ── 4) Wallpaper: genera SVG del tema y lo rasteriza a PNG ────
def gen_wallpaper(tema, ts):
    if not os.path.isfile(SVG_BASE):
        warn(f"No hay {SVG_BASE}; wallpaper omitido."); return None
    plantilla = open(SVG_BASE, encoding="utf-8").read()
    svg = plantilla
    for hexo, rol in kt.WALLPAPER.items():
        svg = re.sub(re.escape(hexo), kt.construir(tema)[rol], svg, flags=re.IGNORECASE)
    slug = tema.lower().replace(" ", "_")
    svg_out = os.path.join(WALL_DIR, f"horus_{slug}.svg")
    png_out = os.path.join(WALL_DIR, f"horus_{slug}.png")
    _escribe_si_cambia(svg_out, svg, f"Wallpaper SVG -> {tema}", ts)
    # rasterizar (magick ya esta en el sistema por el tema de cursor)
    if shutil.which("magick"):
        subprocess.run(["magick", "-background", "none", svg_out,
                        "-resize", "3840x2160", png_out], check=False)
        did(f"Wallpaper PNG 4K -> {png_out}")
    else:
        warn("magick no disponible; quedo solo el SVG.")
    return png_out

def save_state(tema):
    os.makedirs(os.path.dirname(STATE), exist_ok=True)
    open(STATE, "w").write(tema + "\n")

# ── 5) Wallpaper activo: apunta Noctalia al PNG del tema ──────
def set_wallpaper_activo(png, ts):
    dst = os.path.join(CFG, "noctalia", "settings.json")
    if not png or not os.path.isfile(dst):
        warn("settings.json de Noctalia no hallado; wallpaper no apuntado."); return
    txt = open(dst, encoding="utf-8").read()
    # reemplaza el valor de cada "path" del wallpaper (los únicos con /Wallpapers/)
    out = re.sub(r'("path"\s*:\s*")[^"]*Wallpapers/[^"]*(")',
                 lambda m: m.group(1) + png + m.group(2), txt)
    _escribe_si_cambia(dst, out, f"Wallpaper activo (Noctalia) -> {os.path.basename(png)}", ts)

# ── 6) SDDM: MainColor/AccentColor (requiere root; best-effort) ─
def patch_sddm(tema, ts):
    src = os.path.join(REPO, "sugar-dark-horus", "theme.conf")   # fuente Morada
    dst = "/usr/share/sddm/themes/sugar-dark-horus/theme.conf"
    if not os.path.isfile(src):
        warn("theme.conf SDDM (repo) no hallado; SDDM sin recolorear."); return
    out = _sub_hex(open(src, encoding="utf-8").read(), lambda h: True, tema)  # ambos colores rotan
    try:
        actual = subprocess.run(["sudo", "-n", "cat", dst], capture_output=True, text=True)
    except Exception:
        actual = None
    if actual is not None and actual.returncode == 0 and actual.stdout == out:
        skip(f"SDDM theme.conf ya en '{tema}'."); return
    if subprocess.run(["sudo", "-n", "true"], capture_output=True).returncode != 0:
        warn("SDDM omitido: necesita root. Corre 'sudo horus-theme' o aplícalo en el setup."); return
    r = subprocess.run(["sudo", "tee", dst], input=out, text=True, capture_output=True)
    if r.returncode == 0:
        did(f"SDDM theme.conf -> {tema}"); _CAMBIOS[0] = True
    else:
        warn("No se pudo escribir el theme.conf de SDDM.")

# ── fastfetch: logo/keys/title siguen el tema (colores 38;2;R;G;B) ──
def patch_fastfetch(tema, ts):
    # 1) Logo: se copia del repo a ~/.config/fastfetch/logo.txt (texto plano con
    #    placeholders $1/$2; los colores viven en config.jsonc y rotan con el tema)
    logo_src = os.path.join(REPO, "branding", "horus-ascii.txt")
    if os.path.isfile(logo_src):
        logo_txt = open(logo_src, encoding="utf-8").read()
        _escribe_si_cambia(os.path.join(CFG, "fastfetch", "logo.txt"),
                           logo_txt, "fastfetch logo", ts)
    # 2) Config: colores rotados al tema
    src = os.path.join(REPO, "branding", "config.jsonc")
    if not os.path.isfile(src):
        src = "/usr/share/branding/config.jsonc"
    if not os.path.isfile(src):
        warn("config.jsonc de fastfetch no hallado; se omite."); return
    txt = open(src, encoding="utf-8").read()
    def rot(m):
        r, g, b = int(m.group(1)), int(m.group(2)), int(m.group(3))
        nh = kt.rotar_hex("#%02x%02x%02x" % (r, g, b), tema).lstrip("#")
        return "38;2;%d;%d;%d" % (int(nh[0:2],16), int(nh[2:4],16), int(nh[4:6],16))
    out = re.sub(r'38;2;(\d+);(\d+);(\d+)', rot, txt)
    dst = os.path.join(CFG, "fastfetch", "config.jsonc")
    _escribe_si_cambia(dst, out, f"fastfetch -> {tema}", ts)

# ── Asegura modo oscuro por defecto en los settings de Noctalia ──
def _asegura_dark(ts):
    dst = os.path.join(CFG, "noctalia", "settings.json")
    if not os.path.isfile(dst): return
    try: data = json.load(open(dst, encoding="utf-8"))
    except Exception: return
    cs = data.get("colorSchemes")
    if not isinstance(cs, dict) or cs.get("darkMode") is True: return
    cs["darkMode"] = True
    _backup(dst, ts)
    open(dst, "w", encoding="utf-8").write(json.dumps(data, indent=2, ensure_ascii=False) + "\n")
    did("Noctalia: modo oscuro por defecto (darkMode=true).")

def wallpaper_del_tema(tema):
    # Resuelve el PNG pre-generado del tema en el repo (no escribe nada).
    slug = tema.lower().replace(" ", "_")
    for cand in (slug, {"morado": "morada"}.get(slug, slug)):
        p = os.path.join(WALL_DIR, f"horus_{cand}.png")
        if os.path.isfile(p): return p
    warn(f"No hay Wallpapers/horus_{slug}.png en el repo; wallpaper sin cambiar.")
    return None

def patch_cursor(tema):
    slug = tema.lower().replace(" ", "_")
    name = "Bibata-Modern-Purple" if slug == "morado" else f"Bibata-Horus-{slug}"
    if os.path.isdir(os.path.join(HOME, ".icons", name, "cursors")):
        subprocess.run(["horus-cursor", "--apply", name], capture_output=True)
        did(f"Cursor -> {name}")
    else:
        color = kt.rotar_hex("#7a2be8", tema)
        subprocess.Popen(["setsid", "horus-cursor", "--build", name, color, "--apply"],
                         stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        warn(f"Cursor '{name}' generandose en 2o plano (~10 min); se aplicara y notificara solo.")

def stop_noctalia():
    # Se mata ANTES de escribir settings.json: Noctalia guarda su config en
    # memoria al salir y pisaria lo recien escrito (wallpaper/scheme nuevos).
    if shutil.which("qs"):
        subprocess.run(["pkill", "-f", "noctalia-shell"], check=False)
        time.sleep(0.6)

def _pantallas():
    # Nombres de salida segun niri (eDP-1, HDMI-A-1, ...); [""] como fallback.
    try:
        r = subprocess.run(["niri", "msg", "--json", "outputs"], capture_output=True, text=True)
        outs = list(json.loads(r.stdout).keys())
        return outs or [""]
    except Exception:
        return [""]

def reload_hot(png=None):
    # Recargas en caliente sin re-loguear.
    if shutil.which("niri"):
        subprocess.run(["niri", "msg", "action", "load-config-file"], check=False)
    subprocess.run(["pkill", "-USR1", "foot"], check=False)  # foot relee colores con SIGUSR1
    if shutil.which("qs"):
        subprocess.Popen(["setsid", "qs", "-c", "noctalia-shell"],
                         stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        # Noctalia NO lee el path del settings.json al arrancar, y su SET solo
        # REPINTA cuando el path CAMBIA (si el estado ya coincide, no repinta y
        # lo dibujado queda viejo). Truco sin parpadeo: se aplica primero una
        # copia temporal del PNG (path nuevo -> repinta) y luego el path real
        # del repo (cambia otra vez -> repinta lo mismo y el estado queda bien).
        if png:
            tmp = "/tmp/horus-wp-kick.png"
            try:
                shutil.copyfile(png, tmp)
            except Exception:
                tmp = None
            def _set(ruta, scr):
                subprocess.run(["qs", "-c", "noctalia-shell", "ipc", "call",
                                "wallpaper", "set", ruta, scr], capture_output=True)
            def _get(scr):
                r = subprocess.run(["qs", "-c", "noctalia-shell", "ipc", "call",
                                    "wallpaper", "get", scr],
                                   capture_output=True, text=True)
                return r.stdout or ""
            objetivo = tmp or png
            aplicado = False
            for _ in range(30):
                time.sleep(0.5)
                scrs = _pantallas()
                for scr in scrs:
                    _set(objetivo, scr)
                if objetivo in _get(scrs[0]):
                    aplicado = True; break
            if aplicado and tmp:
                # segundo pase: deja el estado en la ruta permanente del repo
                for _ in range(10):
                    time.sleep(0.5)
                    for scr in scrs:
                        _set(png, scr)
                    if png in _get(scrs[0]):
                        break
            if aplicado:
                did(f"Wallpaper -> {os.path.basename(png)} (repintado + estado en repo)")
            else:
                warn("Noctalia no confirmo el wallpaper en 15s; aplicalo desde el selector.")


# ── 7) Teclado RGB (ITE5570 LampArray): color = primary del tema ──
def patch_kbd(tema, ts):
    color = kt.rotar_hex(kt.MORADA["mPrimary"], tema).lstrip("#")
    kbd_state = os.path.join(CFG, "horus", "kbd-color")  # lo lee el autostart
    actual = open(kbd_state).read().strip() if os.path.isfile(kbd_state) else None
    if actual == color:
        skip(f"Teclado RGB: ya en #{color}."); return
    if not shutil.which("horus-kbd-color"):
        warn("horus-kbd-color no está en PATH; teclado sin recolorear."); return
    r = subprocess.run(["horus-kbd-color", color], capture_output=True, text=True)
    if r.returncode == 0:
        os.makedirs(os.path.dirname(kbd_state), exist_ok=True)
        open(kbd_state, "w").write(color + "\n")
        did(f"Teclado RGB -> #{color}"); _CAMBIOS[0] = True
    else:
        warn(f"Teclado RGB no aplicado: {r.stderr.strip() or 'fallo horus-kbd-color'}")

def _cerrar_terminal():
    # Cierra la foot/footclient ancestro de este proceso (si existe). Lo lanzado
    # con setsid (Noctalia, build de cursor) queda fuera del arbol y sobrevive.
    # HORUS_NO_CLOSE la exporta horus-start: si el tema se aplica DENTRO del
    # setup, cerrar la terminal mataria la instalacion entera a media corrida.
    if os.environ.get("HORUS_NO_CLOSE"):
        return
    try:
        pid = os.getppid()
        for _ in range(10):
            if pid <= 1:
                return
            comm = open(f"/proc/{pid}/comm").read().strip()
            if comm in ("foot", "footclient"):
                time.sleep(0.5)
                os.kill(pid, 15)
                return
            pid = int(open(f"/proc/{pid}/status").read().split("PPid:")[1].split()[0])
    except Exception:
        pass

def aplicar(tema):
    canon = _resolver_tema(tema)
    if canon is None:
        sys.exit(f"[err] Tema desconocido: {tema}\n       Disponibles: {', '.join(kt.lista_temas())}")
    tema = canon
    ts = datetime.datetime.now().strftime("%Y%m%d-%H%M%S")
    print(f"{C['p']}Aplicando tema: {tema}{C['n']}  (repo: {REPO})")
    # ── Targets activos del tema ──────────────────────────────
    # El tema recolorea Niri, el teclado RGB, la paleta de Noctalia
    # (colorscheme + regeneración) y foot. El wallpaper se gestiona aparte.
    patch_niri(tema, ts)
    patch_kbd(tema, ts)        # ← teclado RGB sigue el primary del tema
    gen_colorscheme(tema, ts)  # ← reescribe el scheme "Horus Project" (dark + light)
    gen_foot(tema, ts)         # ← foot.ini del tema (ANSI semánticos fijos)\n    recolorear_terminales()    # ← pinta las foot abiertas con el tema entrante
    patch_fastfetch(tema, ts)  # ← logo/keys/title de fastfetch siguen el tema
    patch_cursor(tema)         # cursor Bibata del tema (build en 2o plano si falta)
    # patch_gtk(tema, ts)      # (pendiente) carpetas de Thunar / acento GTK
    save_state(tema)
    # ── Wallpaper del tema + reinicio de Noctalia (orden anti-carrera) ──
    png = wallpaper_del_tema(tema)
    sj = os.path.join(CFG, "noctalia", "settings.json")
    wp_cambia = bool(png) and os.path.isfile(sj) and png not in open(sj, encoding="utf-8").read()
    if _CAMBIOS[0] or wp_cambia:
        stop_noctalia()            # 1. matar (o guardaria settings viejos al salir)
        set_wallpaper_activo(png, ts)  # 2. escribir wallpaper del tema
        _asegura_dark(ts)              # 3. asegurar modo oscuro
        reload_hot(png)                # 4. arrancar Noctalia + wallpaper via IPC
        did(f"Tema '{tema}' aplicado (Niri + Noctalia + foot + teclado + wallpaper + cursor). Respaldo: {os.path.join(BK_ROOT, ts)}")
    else:
        skip(f"Todo ya estaba en '{tema}'. Sin cambios.")
    _cerrar_terminal()

def _elegir():
    """Selector interactivo: lista los temas numerados y aplica el elegido."""
    temas = kt.lista_temas()
    cur = open(STATE).read().strip() if os.path.isfile(STATE) else None
    def e(s=""): print(s, file=sys.stderr)
    while True:
        e(f"{C['p']}╭─ Tema de Horus Project ─╮{C['n']}")
        for i, t in enumerate(temas, 1):
            sw = _swatch(kt.construir(t)["mPrimary"])
            marca = f" {C['ok']}(actual){C['n']}" if t == cur else ""
            e(f"  {C['ok']}{i:>2}{C['n']}) {sw}  {t}{marca}")
        print("  > ", end="", file=sys.stderr, flush=True)
        try:
            r = input().strip()
        except (EOFError, KeyboardInterrupt):
            e("\nCancelado."); return
        if r.isdigit() and 1 <= int(r) <= len(temas):
            aplicar(temas[int(r) - 1]); return
        if _resolver_tema(r):
            aplicar(r); return
        e(f"  {C['warn']}Opcion no valida.{C['n']}")

def main():
    a = sys.argv[1:]
    if a and a[0] in ("-h", "--help"):
        print("uso: horus-theme [Tema] | --elegir | --lista | --actual\n"
              "  sin argumentos abre el selector interactivo"); return
    if not a or a[0] == "--elegir":
        _elegir(); return
    if a[0] == "--lista":
        cur = open(STATE).read().strip() if os.path.isfile(STATE) else "(ninguno)"
        for t in kt.lista_temas():
            print(f"  {'* ' if t == cur else '  '}{t}")
        return
    if a[0] == "--actual":
        print(open(STATE).read().strip() if os.path.isfile(STATE) else "(ninguno)")
        return
    aplicar(" ".join(a))

if __name__ == "__main__":
    main()
