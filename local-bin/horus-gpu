#!/usr/bin/env bash
# horus-gpu — lanzador consciente del PERFIL y del CARGADOR. Prefijo global del launcher
# de Noctalia; sirve para cualquier app (juegos, render, diseño).
#   silencio (quiet)             -> iGPU exclusivo.
#   EN BATERÍA (cualquier perfil) -> iGPU exclusivo (no drena la dGPU).
#   equilibrado/rendimiento + AC  -> ofrece la dGPU (offload).
# Maneja binarios (prime-run) y Flatpaks ('flatpak run' -> inyecta --env). Idempotente.
[ "$(basename "${1:-}")" = horus-gpu ] && shift
[ $# -eq 0 ] && exit 0

_en_ac(){ for p in /sys/class/power_supply/*/online; do
    [ -r "$p" ] && [ "$(cat "$p" 2>/dev/null)" = "1" ] && return 0; done; return 1; }

prof=$(cat /sys/firmware/acpi/platform_profile 2>/dev/null)
# iGPU si: silencio, o vas en batería (candado de energía)
if [ "$prof" = quiet ] || ! _en_ac; then exec "$@"; fi

# equilibrado/rendimiento + cargador: ofrecer la dGPU
if [ "$1" = flatpak ]; then
    out=(); inj=0
    for a in "$@"; do out+=("$a")
        if [ "$a" = run ] && [ $inj -eq 0 ]; then
            out+=(--env=__NV_PRIME_RENDER_OFFLOAD=1 --env=__GLX_VENDOR_LIBRARY_NAME=nvidia --env=__VK_LAYER_NV_optimus=NVIDIA_only); inj=1
        fi
    done
    exec "${out[@]}"
fi
command -v prime-run >/dev/null && exec prime-run "$@"
exec "$@"
