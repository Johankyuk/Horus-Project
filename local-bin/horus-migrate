#!/usr/bin/env bash
# horus-migrate — migra una instalación existente de "Kyu OS" al branding Horus Project.
# One-shot e idempotente: cada paso verifica antes de tocar. Al final corre horus-start
# para redesplegar todo con los nombres nuevos.
set -uo pipefail
P='\033[0;35m'; G='\033[0;32m'; Y='\033[1;33m'; N='\033[0m'
did()  { printf "${G}[+]${N} %s\n" "$1"; }
skip() { printf "    %s (ya estaba)\n" "$1"; }
warn() { printf "${Y}[!]${N} %s\n" "$1"; }

printf "${P}── Migración Kyu OS → Horus Project ──${N}\n"

# 1. Configs y cache de usuario
if [ -d "$HOME/.config/kyu-os" ] && [ ! -d "$HOME/.config/horus" ]; then
    mv "$HOME/.config/kyu-os" "$HOME/.config/horus" && did "~/.config/kyu-os → ~/.config/horus"
else skip "~/.config/horus"; fi
if [ -d "$HOME/.cache/kyu-os" ] && [ ! -d "$HOME/.cache/horus" ]; then
    mv "$HOME/.cache/kyu-os" "$HOME/.cache/horus" && did "~/.cache/kyu-os → ~/.cache/horus"
else skip "~/.cache/horus"; fi

# 2. Repo: ~/kyu-os → ~/horus (+ pointer + remote)
if [ -d "$HOME/kyu-os" ] && [ ! -d "$HOME/horus" ]; then
    mv "$HOME/kyu-os" "$HOME/horus" && did "repo ~/kyu-os → ~/horus"
fi
if [ -d "$HOME/horus/.git" ]; then
    mkdir -p "$HOME/.config/horus"
    echo "$HOME/horus" > "$HOME/.config/horus/repo"
    git -C "$HOME/horus" remote set-url origin "https://github.com/Johankyuk/Horus-Project.git" 2>/dev/null \
        && did "remote origin → github.com/Johankyuk/Horus-Project (renombra el repo en GitHub si no lo has hecho)"
fi

# 3. Atajos viejos kyu-* fuera del PATH (horus-start despliega los nuevos)
old=$(ls "$HOME/.local/bin"/kyu-* 2>/dev/null | wc -l)
if [ "$old" -gt 0 ]; then
    rm -f "$HOME/.local/bin"/kyu-* && did "$old atajos kyu-* retirados de ~/.local/bin"
else skip "sin atajos kyu-* viejos"; fi

# 4. Noctalia: scheme "Kyu OS" → "Horus Project"
CS="$HOME/.config/noctalia/colorschemes"
if [ -d "$CS/Kyu OS" ]; then
    mv "$CS/Kyu OS" "$CS/Horus Project"
    [ -f "$CS/Horus Project/Kyu OS.json" ] && mv "$CS/Horus Project/Kyu OS.json" "$CS/Horus Project/Horus Project.json"
    did "scheme Noctalia → 'Horus Project'"
fi
SJ="$HOME/.config/noctalia/settings.json"
if [ -f "$SJ" ] && grep -q '"Kyu OS"' "$SJ"; then
    sed -i 's/"Kyu OS"/"Horus Project"/g' "$SJ" && did "settings.json → scheme 'Horus Project'"
fi

# 5. bashrc: marca del prompt
if grep -q '# kyu-prompt' "$HOME/.bashrc" 2>/dev/null; then
    sed -i 's/# kyu-prompt/# horus-prompt/' "$HOME/.bashrc" && did "marca horus-prompt en ~/.bashrc"
fi

# 6. Sistema (sudo): servicios, hooks, reglas y binarios con nombre viejo.
#    Solo se RETIRA lo viejo; horus-start reinstala las versiones nuevas.
if sudo -v; then
    if systemctl is-enabled kyu-power-hook.service &>/dev/null; then
        sudo systemctl disable --now kyu-power-hook.service &>/dev/null
        sudo rm -f /etc/systemd/system/kyu-power-hook.service
        sudo systemctl daemon-reload
        did "kyu-power-hook.service retirado"
    fi
    for f in /usr/local/bin/kyu-os-title /etc/pacman.d/hooks/zzz-kyu-branding.hook \
             /etc/udev/rules.d/60-kyu-kbd.rules /etc/modprobe.d/kyu-nvidia-pm.conf \
             /etc/udev/rules.d/80-kyu-nvidia-pm.rules /etc/systemd/logind.conf.d/10-kyu-lock.conf; do
        sudo test -f "$f" && sudo rm -f "$f" && did "retirado: $f"
    done
    if [ -d /usr/share/sddm/themes/sugar-dark-kyu ]; then
        sudo mv /usr/share/sddm/themes/sugar-dark-kyu /usr/share/sddm/themes/sugar-dark-horus
        sudo sed -i 's/sugar-dark-kyu/sugar-dark-horus/g' /etc/sddm.conf.d/*.conf 2>/dev/null
        did "tema SDDM → sugar-dark-horus"
    fi
else
    warn "Sin sudo: los restos de sistema (servicio, hooks, SDDM) quedan pendientes."
fi

# 7. Redesplegar todo con nombres nuevos
REPO=$(cat "$HOME/.config/horus/repo" 2>/dev/null || echo "$HOME/horus")
if [ -x "$REPO/setup_master.sh" ]; then
    printf "${P}── Redesplegando (horus-start) ──${N}\n"
    bash "$REPO/setup_master.sh" "$@"
else
    warn "No encuentro el repo en $REPO; corre horus-start a mano."
fi
echo "✓ Migración a Horus Project completa"
