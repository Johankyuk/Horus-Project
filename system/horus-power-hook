#!/usr/bin/env bash
# horus-power-hook — ata la dGPU y los ventiladores al PERFIL de energía (lo que
# declara Noctalia/Niri vía /sys/firmware/acpi/platform_profile). Servicio root.
# NO se usa horus-power a mano: reacciona al toggle de Noctalia.
#
#   WATTS dGPU (cuando está despierta por un juego):
#     silencio -> mínimo (normalmente dormida = 0W) · equilibrado -> ~50W · rendimiento -> máximo.
#   VENTILADORES:
#     rendimiento + cargador -> curva agresiva SUAVE, tope ~70% (sube con la temp, sin turbinazo).
#     en batería o fuera de rendimiento -> curva normal (silenciosa). Respeta el gasto en batería.
set -uo pipefail
PROF_FILE=/sys/firmware/acpi/platform_profile
BAL_W=50   # wataje del perfil equilibrado (rango 30~60)

# Curva normal de rendimiento (batería / fallback): sube tarde, silenciosa; 100% solo por seguridad térmica.
CURVA_PERF="35c:12%,50c:24%,62c:38%,72c:52%,80c:66%,86c:80%,91c:100%,96c:100%"
# Rendimiento + AC ("noheat" suave): arranca antes, TOPE ~70%; sobre 88°C sube algo solo por seguridad.
CURVA_PERF_AC="35c:22%,45c:36%,55c:50%,63c:60%,70c:70%,80c:70%,88c:78%,95c:90%"

command -v nvidia-smi >/dev/null || echo "Sin nvidia-smi; solo gestiono ventiladores."
[ -r "$PROF_FILE" ] || { echo "Sin platform_profile; nada que hacer."; exit 0; }

_en_ac(){ for p in /sys/class/power_supply/*/online; do
    [ -r "$p" ] && [ "$(cat "$p" 2>/dev/null)" = "1" ] && return 0; done; return 1; }
_min_w(){ nvidia-smi --query-gpu=power.min_limit --format=csv,noheader,nounits 2>/dev/null | tr -d ' ' | cut -d. -f1; }
_max_w(){ nvidia-smi --query-gpu=power.max_limit --format=csv,noheader,nounits 2>/dev/null | tr -d ' ' | cut -d. -f1; }
_cur_w(){ nvidia-smi --query-gpu=power.limit    --format=csv,noheader,nounits 2>/dev/null | tr -d ' ' | cut -d. -f1; }
_target_w(){ local mn mx; mn=$(_min_w); mx=$(_max_w)
    case "$1" in
        quiet)       echo "${mn:-30}" ;;
        balanced)    local m=$BAL_W; [ -n "$mx" ] && [ "$m" -gt "$mx" ] && m=$mx; echo "$m" ;;
        performance) echo "${mx:-100}" ;;
        *)           echo "" ;;
    esac
}
_set_perf_curve(){ # $1 = data
    command -v asusctl >/dev/null || return 0
    asusctl fan-curve --mod-profile performance --fan cpu --data "$1" &>/dev/null
    asusctl fan-curve --mod-profile performance --fan gpu --data "$1" &>/dev/null
    asusctl fan-curve --mod-profile performance --enable-fan-curves true &>/dev/null
}

fan_state=""
while :; do
    prof="$(cat "$PROF_FILE" 2>/dev/null || true)"

    # --- Ventiladores: agresivo-suave (70%) solo en rendimiento + AC ---
    if [ "$prof" = performance ] && _en_ac; then want=ac; else want=normal; fi
    if [ "$want" != "$fan_state" ]; then
        [ "$want" = ac ] && _set_perf_curve "$CURVA_PERF_AC" || _set_perf_curve "$CURVA_PERF"
        logger -t horus-power-hook "curva rendimiento -> $want (perfil $prof)"
        fan_state="$want"
    fi

    # --- Watts dGPU: solo si está despierta ---
    if nvidia-smi -q -d POWER &>/dev/null; then
        w="$(_target_w "$prof")"; cur="$(_cur_w)"
        if [ -n "$w" ] && [ "$w" != "$cur" ] && nvidia-smi -pl "$w" &>/dev/null; then
            logger -t horus-power-hook "perfil $prof + dGPU despierta -> ${w}W"
        fi
    fi
    sleep 2
done
